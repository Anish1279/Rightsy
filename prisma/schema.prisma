// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SessionStatus {
  ACTIVE
  REVOKED
  COMPROMISED
  EXPIRED
}

model User {
  id                  String                 @id @default(cuid())
  email               String                 @unique
  name                String?
  passwordHash        String                 @map("password")
  role                UserRole               @default(USER)
  emailVerifiedAt     DateTime?
  passwordChangedAt   DateTime?
  failedLoginCount    Int                    @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  sessions            Session[]
  refreshTokens       RefreshToken[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  authAuditLogs       AuthAuditLog[]
  assessmentAttempts  AssessmentAttempt[]
  assessmentProgress  AssessmentProgress[]
  achievements        Achievement[]
  learningEvents      LearningEvent[]
  assessmentSummary   UserAssessmentSummary?

  @@index([role])
  @@index([emailVerifiedAt])
  @@index([lockedUntil])
}

model Session {
  id                 String         @id @default(cuid())
  userId             String
  status             SessionStatus  @default(ACTIVE)
  refreshTokenFamily String         @unique
  userAgent          String?
  ipAddress          String?
  lastSeenAt         DateTime       @default(now())
  expiresAt          DateTime
  revokedAt          DateTime?
  revocationReason   String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens      RefreshToken[]

  @@index([userId, status, createdAt])
  @@index([expiresAt])
}

model RefreshToken {
  id                String    @id @default(cuid())
  tokenHash         String    @unique
  tokenFamilyId     String
  userId            String
  sessionId         String
  expiresAt         DateTime
  createdByIp       String?
  userAgent         String?
  rotatedAt         DateTime?
  revokedAt         DateTime?
  replacedByTokenId String?
  reuseDetectedAt   DateTime?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  session           Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, revokedAt])
  @@index([userId, expiresAt])
  @@index([tokenFamilyId])
  @@index([expiresAt])
}

model VerificationToken {
  id         String    @id @default(cuid())
  userId     String?
  email      String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, consumedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  requestedIp String?
  userAgent   String?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

model AuthAuditLog {
  id           String   @id @default(cuid())
  userId       String?
  event        String
  ipAddress    String?
  userAgent    String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, event, createdAt])
  @@index([event, createdAt])
}

model AssessmentAttempt {
  id                 String    @id @default(cuid())
  userId             String
  kind               String
  moduleId           String
  score              Int
  maxScore           Int
  xpEarned           Int
  accuracy           Float
  masteryDelta       Float     @default(0)
  durationMs         Int
  startedAt          DateTime?
  completedAt        DateTime  @default(now())
  answersJson        String
  breakdownJson      String
  integrityFlagsJson String    @default("[]")
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, moduleId, createdAt])
  @@index([userId, createdAt])
}

model AssessmentProgress {
  id              String    @id @default(cuid())
  userId          String
  kind            String
  moduleId        String
  bestScore       Int       @default(0)
  bestAccuracy    Float     @default(0)
  attempts        Int       @default(0)
  mastery         Float     @default(0)
  xp              Int       @default(0)
  level           Int       @default(1)
  streakCount     Int       @default(0)
  lastCompletedAt DateTime?
  weakTopicsJson  String    @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, moduleId])
  @@index([userId, kind])
}

model UserAssessmentSummary {
  id             String    @id @default(cuid())
  userId         String    @unique
  totalXp        Int       @default(0)
  level          Int       @default(1)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActivityAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id             String   @id @default(cuid())
  userId         String
  achievementKey String
  title          String
  description    String
  metadataJson   String   @default("{}")
  unlockedAt     DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([userId, unlockedAt])
}

model LearningEvent {
  id           String   @id @default(cuid())
  userId       String
  eventType    String
  kind         String
  moduleId     String
  questionId   String?
  quality      String?
  score        Int?
  durationMs   Int?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType, createdAt])
  @@index([userId, kind, moduleId])
}
